{
  "name": "versatile",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.{js,vue}",
    "lint:tokens": "node scripts/lint-tokens.mjs",
    "lint:fix": "eslint src/**/*.{js,vue} --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css}\"",
    "eval:rag": "npx vite-node scripts/evaluate-rag.js",
    "eval:scene": "npx vite-node scripts/evaluate-scene-retrieval.js",
    "pipeline:quality": "npx vite-node scripts/ml-pipelines/quality-regression/evaluate.js",
    "pipeline:benchmark": "npx vite-node scripts/ml-pipelines/model-benchmarking/evaluate.js",
    "pipeline:active": "npx vite-node scripts/ml-pipelines/active-learning/analyze.js",
    "pipeline:active:sample": "npx vite-node scripts/ml-pipelines/active-learning/analyze.js --source scripts/ml-pipelines/active-learning/sample-eval-history.json",
    "pipeline:curate": "npx vite-node scripts/ml-pipelines/fine-tuning-curation/curate.js",
    "pipeline:curate:sample": "npx vite-node scripts/ml-pipelines/fine-tuning-curation/curate.js --source scripts/ml-pipelines/active-learning/sample-eval-history.json",
    "pipeline:drift": "npx vite-node scripts/ml-pipelines/drift-monitor/monitor.js",
    "pipeline:drift:sample": "npx vite-node scripts/ml-pipelines/drift-monitor/monitor.js --source scripts/ml-pipelines/active-learning/sample-eval-history.json",
    "pipeline:drift:synthetic": "npx vite-node scripts/ml-pipelines/drift-monitor/monitor.js --source scripts/ml-pipelines/drift-monitor/sample-drift-evals.json --threshold 1",
    "pipeline:drift:edge": "npx vite-node scripts/ml-pipelines/drift-monitor/monitor.js --source scripts/ml-pipelines/drift-monitor/sample-drift-edge-evals.json --threshold 1"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/pm": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "@tiptap/vue-3": "^2.1.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^10.7.0",
    "dexie": "^3.2.0",
    "focus-trap": "^8.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-vue-next": "^1.0.0",
    "pdfjs-dist": "^6.0.227",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
